{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN" },
                "1": { "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "expr": "max(up{job=\"ti-garantias-dev-backend\", instance=~\"$instance\"})", "refId": "A" }],
      "title": "Backend dev (UP/DOWN)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 9, "x": 6, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "(sum(rate(microsoft_aspnetcore_hosting_http_server_request_duration_count{job=\"ti-garantias-dev-backend\", instance=~\"$instance\"}[1m])) or sum(rate(http_requests_received_total{job=\"ti-garantias-dev-backend\", instance=~\"$instance\"}[1m])) or vector(0))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "title": "Solicitudes por segundo",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 5, "w": 9, "x": 15, "y": 0 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "(sum(rate(microsoft_aspnetcore_hosting_http_server_request_duration_count{job=\"ti-garantias-dev-backend\", instance=~\"$instance\", http_response_status_code=~\"5..\"}[5m])) or sum(rate(http_requests_received_total{job=\"ti-garantias-dev-backend\", instance=~\"$instance\", code=~\"5..\"}[5m])) or vector(0))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ],
      "title": "Errores HTTP 5xx",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"ti-garantias-dev-backend\", instance=~\"$instance\"}[5m]) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "CPU del proceso backend (% de 1 core)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "process_working_set_bytes{job=\"ti-garantias-dev-backend\", instance=~\"$instance\"}", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "title": "Memoria del proceso backend (Working Set)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (compose_service) (rate({compose_service=~\"$service\"}[1m]))",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "title": "Volumen de logs de la VM (Loki)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "ops", "min": 0 }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (compose_service) (rate({compose_service=~\"$service\"} |= \"error\"[5m]))",
          "legendFormat": "{{compose_service}}",
          "refId": "A"
        }
      ],
      "title": "Errores en logs de la VM (\"error\"/5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 8,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": true, "showLabels": false, "wrapLogMessage": true },
      "targets": [
        { "expr": "{compose_service=~\"$service\"}", "refId": "A" }
      ],
      "title": "Logs en tiempo real de la VM",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ti-garantias", "health", "realtime"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"ti-garantias-dev-backend\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "selected": false, "text": "All", "value": ".*" }
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({compose_service=~\".+\"}, compose_service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": { "selected": false, "text": "All", "value": ".+" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TI Garantias - Health (Realtime)",
  "uid": "ti-garantias-health-realtime",
  "version": 5
}
